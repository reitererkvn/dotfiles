#!/bin/sh
######################################################################
### UWSM Master Environment Loader                                 ###
######################################################################

ENV_DIR="$HOME/.config/uwsm/env.d"

if [ -d "$ENV_DIR" ]; then
    for config_file in "$ENV_DIR"/*.sh; do
        if [ -r "$config_file" ]; then
            . "$config_file"
        fi
    done
fi
