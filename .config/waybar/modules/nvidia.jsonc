{
    "custom/nvidia": {
     "exec": "nvidia-smi --query-gpu=utilization.gpu,temperature.gpu,memory.used,memory.total --format=csv,noheader,nounits | awk -F', ' '{printf \"{\\\"text\\\": \\\"%s%% %s°C | %d%%\\\", \\\"tooltip\\\": \\\"VRAM: %s MiB / %s MiB\\\"}\\n\", $1, $2, ($3/$4)*100, $3, $4}'",
     "return-type": "json",
     "interval": 2,
     "format": "{} 󰢮 ",
     "tooltip": true
    }
}
