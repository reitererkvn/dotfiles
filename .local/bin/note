#!/bin/bash
# Verzeichnis definieren
NOTES_DIR="$HOME/Dokumente/notes"
FM="${FILEMANAGER:-xdg-open}"
mkdir -p "$NOTES_DIR"

case "$1" in
    -l|--list|list)
        # Option: Liste alle Notizen chronologisch (neueste oben)
        ls -t "$NOTES_DIR"
        ;;

    -ly|--listyazi|listy)
        # Option: Files in filemanager anzeigen
        $FM "$NOTES_DIR"
        ;;

    *)
        # Standard: Öffne die heutige Notiz
        TODAY=$(date +%Y-%m-%d)
        NOTE_FILE="$NOTES_DIR/$TODAY.md"

        # Prüfen, ob die Datei noch NICHT existiert (-f testet auf File)
        if [ ! -f "$NOTE_FILE" ]; then
            # Header und eine Leerzeile injizieren
            echo "# Notiz $TODAY" > "$NOTE_FILE"
            echo "" >> "$NOTE_FILE"
        fi

        # Editor aufrufen und direkt ans Ende der Datei springen (+)
        $EDITOR + "$NOTE_FILE"
        ;;
esac
